# Static export served from Apache shared hosting.
# Companion to next.config.ts `output: "export"` + `trailingSlash: true`.

Options -MultiViews
DirectoryIndex index.html

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "DENY"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the request is not for an existing file or directory, append a trailing
  # slash so URLs like /propiedades resolve to /propiedades/index.html.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !\.[a-zA-Z0-9]+$
  RewriteCond %{REQUEST_URI} !/$
  RewriteRule ^(.*)$ /$1/ [L,R=301]
</IfModule>

# 404 fallback page generated by Next.js.
ErrorDocument 404 /404.html
